# ============================================================================
# KuKuMBA — production environment. Copy to .env.production and fill in.
# Compose reads this for interpolation AND injects it into the api container.
# Create a symlink so compose auto-loads it (then no --env-file needed):
#   ln -sf .env.production .env
# ============================================================================

# ── Database password — THE ONLY place you set it ──
# DATABASE_URL is built automatically from these in docker-compose.prod.yml,
# so the API and Postgres always agree (no P1000 mismatch).
# Use a URL-safe value (hex/alphanumeric, NO @ : / ? # %). Generate one:
#   openssl rand -hex 24
POSTGRES_USER=kukumba
POSTGRES_PASSWORD=CHANGE_ME_run_openssl_rand_hex_24
POSTGRES_DB=kukumba

# ── Auth secrets — generate each with:  openssl rand -hex 32 ──
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

DEFAULT_RTP=0.973
# "mock" = sandbox (no real money). Implement & switch a real provider later.
PAYMENT_PROVIDER=mock

# ── Admin account created by the seed ──
ADMIN_EMAIL=admin@kukumba.space
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_USERNAME=kukumba_admin
DEMO_SIGNUP_BONUS=5000

# Seed the DB on first boot (currencies, game, VIP, admin, content, demo raffle).
# true for the FIRST deploy, then set to false and redeploy.
SEED_ON_START=true

# Email for Let's Encrypt renewal notices (used by deploy/init-letsencrypt.sh)
CERTBOT_EMAIL=you@example.com
# Set to 1 to test against the LE staging CA (avoids rate limits while debugging)
CERTBOT_STAGING=0
