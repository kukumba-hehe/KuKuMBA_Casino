# ─────────────────────────────────────────────────────────────
# KuKuMBA — environment configuration
# Copy to .env and adjust. Everything is modular & overridable.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://kukumba:kukumba_dev_pw@127.0.0.1:5432/kukumba?schema=public"

# Redis (optional — used by the realtime gateway for horizontal scaling).
# Leave empty to use the in-memory adapter (fine for a single instance / dev).
REDIS_URL="redis://127.0.0.1:6379"

# API
API_PORT=3000
WEB_ORIGIN="http://localhost:5173"

# Auth / JWT — CHANGE THESE IN PRODUCTION
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Game config — fallback RTP if neither the game row nor the game.rtp setting is set.
# Default European roulette is 0.973 (house edge 2.7%).
DEFAULT_RTP="0.973"

# Payments — adapter selection. "mock" runs a sandbox provider (no real money).
# Plug a real crypto gateway / fiat PSP by implementing a provider and switching this.
PAYMENT_PROVIDER="mock"

# Seed / bootstrap admin
ADMIN_EMAIL="admin@kukumba.local"
ADMIN_PASSWORD="admin12345"
ADMIN_USERNAME="kukumba_admin"

# Demo economy
DEMO_SIGNUP_BONUS="5000"
